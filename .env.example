# PLAN.EX Environment Variables Template
# Copy this file to .env.local for local development

# ============================================
# Firebase Configuration (Cloud Backend & RAG)
# ============================================
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_ALLOWED_AUTH_ORIGINS=http://localhost:3000,https://your-production-domain.com

# ============================================
# OAuth Providers (Google + GitHub + Email)
# ============================================
VITE_ENABLE_GOOGLE_AUTH=true
VITE_ENABLE_GITHUB_AUTH=true
VITE_ENABLE_EMAIL_AUTH=true
# ============================================
# Stripe Configuration (Payment)
# ============================================
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# ============================================
# App Configuration
# ============================================
VITE_APP_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000/api

# ============================================
# Feature Flags
# ============================================
# Enable cloud sync (Firebase Firestore)
VITE_ENABLE_SYNC=true

# Enable AI features (requires OpenAI API, Pro plan only)
VITE_ENABLE_AI_FEATURES=false

# Enable social features (study rooms, leaderboard)
VITE_ENABLE_SOCIAL_FEATURES=false

# ============================================
# Environment
# ============================================
VITE_ENV=development

# ============================================
# Optional: Email Service (SendGrid/Resend)
# ============================================
# VITE_SENDGRID_API_KEY=your_sendgrid_api_key

# ============================================
# Optional: OpenAI (AI Features - Pro)
# ============================================
# VITE_OPENAI_API_KEY=your_openai_api_key
